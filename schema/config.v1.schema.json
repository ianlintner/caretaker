{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/your-org/caretaker/schema/config.v1.schema.json",
  "title": "Caretaker Config v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "orchestrator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schedule": {
          "type": "string",
          "enum": ["hourly", "daily", "weekly", "manual"]
        },
        "summary_issue": { "type": "boolean" },
        "dry_run": { "type": "boolean" }
      }
    },
    "pr_agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "auto_merge": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "copilot_prs": { "type": "boolean" },
            "dependabot_prs": { "type": "boolean" },
            "human_prs": { "type": "boolean" },
            "merge_method": {
              "type": "string",
              "enum": ["squash", "merge", "rebase"]
            }
          }
        },
        "copilot": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_retries": { "type": "integer", "minimum": 0 },
            "retry_window_hours": { "type": "integer", "minimum": 0 },
            "context_injection": { "type": "boolean" }
          }
        },
        "ci": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "flaky_retries": { "type": "integer", "minimum": 0 },
            "ignore_jobs": {
              "type": "array",
              "items": { "type": "string" }
            },
            "close_managed_prs_on_backlog": { "type": "boolean" },
            "auto_approve_workflows": { "type": "boolean" }
          }
        },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "auto_approve_copilot": { "type": "boolean" },
            "nitpick_threshold": {
              "type": "string",
              "enum": ["low", "high"]
            }
          }
        }
      }
    },
    "issue_agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "auto_assign_bugs": { "type": "boolean" },
        "auto_assign_features": { "type": "boolean" },
        "auto_close_stale_days": { "type": "integer", "minimum": 1 },
        "auto_close_questions": { "type": "boolean" },
        "labels": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bug": {
              "type": "array",
              "items": { "type": "string" }
            },
            "feature": {
              "type": "array",
              "items": { "type": "string" }
            },
            "question": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "upgrade_agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "strategy": {
          "type": "string",
          "enum": ["auto-minor", "auto-patch", "latest", "pinned", "manual"]
        },
        "channel": {
          "type": "string",
          "enum": ["stable", "preview"]
        },
        "auto_merge_non_breaking": { "type": "boolean" }
      }
    },
    "charlie_agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "stale_days": { "type": "integer", "minimum": 1 },
        "close_duplicate_issues": { "type": "boolean" },
        "close_duplicate_prs": { "type": "boolean" },
        "close_stale_issues": { "type": "boolean" },
        "close_stale_prs": { "type": "boolean" },
        "exempt_labels": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "escalation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "targets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stale_days": { "type": "integer", "minimum": 1 },
        "labels": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "llm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claude_enabled": {
          "type": "string",
          "enum": ["auto", "true", "false"]
        },
        "claude_features": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "goal_engine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "goal_driven_dispatch": { "type": "boolean" },
        "divergence_threshold": { "type": "integer", "minimum": 1 },
        "stale_threshold": { "type": "integer", "minimum": 1 },
        "max_history": { "type": "integer", "minimum": 1 }
      }
    },
    "azure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "use_managed_identity": { "type": "boolean" }
      }
    },
    "mcp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "endpoint": { "type": ["string", "null"] },
        "auth_mode": {
          "type": "string",
          "enum": ["none", "managed_identity", "token", "apim"]
        },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "allowed_tools": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "application_insights_connection_string_env": { "type": "string" }
      }
    },
    "review_agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": {
          "type": "string",
          "enum": ["scheduled", "targeted"]
        },
        "lookback_runs": { "type": "integer", "minimum": 1 },
        "lookback_days": { "type": "integer", "minimum": 1 },
        "artifact_dir": { "type": "string" },
        "save_markdown": { "type": "boolean" },
        "save_json": { "type": "boolean" },
        "save_manifest": { "type": "boolean" },
        "publish_summary_comments": { "type": "boolean" },
        "comment_on_prs": { "type": "boolean" },
        "comment_on_issues": { "type": "boolean" },
        "minimum_comment_score": { "type": "integer", "minimum": 0 },
        "use_llm_for_retro": { "type": "boolean" }
      }
    },
    "memory_store": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "db_path": { "type": "string" },
        "snapshot_path": { "type": "string" },
        "max_entries_per_namespace": { "type": "integer", "minimum": 1 }
      }
    },
    "github_app": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "app_id": { "type": ["integer", "null"], "minimum": 1 },
        "private_key_env": { "type": "string" },
        "webhook_secret_env": { "type": "string" },
        "oauth_client_id_env": { "type": "string" },
        "oauth_client_secret_env": { "type": "string" },
        "public_base_url": { "type": ["string", "null"] },
        "installation_token_refresh_skew_seconds": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
